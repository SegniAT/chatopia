{
    admin 0.0.0.0:2019
    metrics
    order rate_limit before reverse_proxy
}

:80 {
    handle /peerjs* {
        reverse_proxy peerjs-server:9000
    }

    handle {
        reverse_proxy web:4000
    }

    rate_limit {
        zone general {
            key {remote_host}
            events 30
            window 1m
            match {
                path /
                path /about
                path /live_users
            }
        }
        zone session {
            key {remote_host}
            events 10
            window 1m
            match {
                path /chat/
            }
        }
        zone ws_upgrade {
            key {remote_host}
            events 10
            window 1m
            match {
                path /chat-ws*
            }
        }
    }

    # Static Assets Cache
    @static {
        path /assets/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Security Headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
