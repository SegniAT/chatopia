# ENVIRONMENT
ENV=development
INSTANCE_NAME=chatopia

# INFRASTRUCTURE PORTS & ADDRS
# For local dev outside docker, use localhost. For docker-compose mesh, use container names.
APP_PORT=4000
REDIS_ADDR=localhost:6379
PEERJS_ADDR=localhost:9000

# METRICS & OBSERVABILITY
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# SECRETS (Change these in production!)
SESSION_SECRET=your_32_byte_development_secret_here_replace_me
REDIS_PASSWORD=admin
GRAFANA_ADMIN_PASSWORD=admin

# TURN/STUN (Metered.ca)
TURN_USERNAME=
TURN_CREDENTIAL=
